<Window x:Class="ReceiverWinUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxMic Receiver WinUI"
        Height="760"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#0B1320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E5EDF8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="Background" Value="#1C3554" />
            <Setter Property="BorderBrush" Value="#3A6EA8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#13233A" />
            <Setter Property="BorderBrush" Value="#2A4970" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="Background" Value="#11243B" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1C3C62" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A6FB0" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="Background" Value="#11243B" />
            <Setter Property="BorderBrush" Value="#3A6EA8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#DCE9F9" />
            <Setter Property="Background" Value="#0E1D31" />
            <Setter Property="BorderBrush" Value="#31567E" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="FluxMic Receiver (WinUI/WPF)" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="WebSocket + Audio Inject + Action Execution" Opacity="0.82" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="MinimizeTrayButton" Content="Minimize To Tray" Click="MinimizeTrayButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Connection" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Server" Grid.Row="0" Grid.Column="0" />
                            <TextBlock x:Name="ServerStatusValue" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />

                            <TextBlock Text="Server URL" Grid.Row="1" Grid.Column="0" />
                            <TextBlock x:Name="ServerAddressValue" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />

                            <TextBlock Text="Clients" Grid.Row="2" Grid.Column="0" />
                            <TextBlock x:Name="ClientIpValue" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" />

                            <TextBlock Text="RTT" Grid.Row="3" Grid.Column="0" />
                            <TextBlock x:Name="RttValue" Grid.Row="3" Grid.Column="1" />

                            <TextBlock Text="Jitter" Grid.Row="4" Grid.Column="0" />
                            <TextBlock x:Name="JitterValue" Grid.Row="4" Grid.Column="1" />

                            <TextBlock Text="Buffered" Grid.Row="5" Grid.Column="0" />
                            <TextBlock x:Name="BufferedValue" Grid.Row="5" Grid.Column="1" />

                            <TextBlock Text="Mute" Grid.Row="6" Grid.Column="0" />
                            <TextBlock x:Name="MuteValue" Grid.Row="6" Grid.Column="1" />

                            <TextBlock Text="Actions" Grid.Row="7" Grid.Column="0" />
                            <TextBlock x:Name="ActionsValue" Grid.Row="7" Grid.Column="1" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Audio Device / Driver" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Driver" Grid.Row="0" Grid.Column="0" />
                            <TextBlock x:Name="DriverValue" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />

                            <TextBlock Text="Codec" Grid.Row="1" Grid.Column="0" />
                            <TextBlock x:Name="CodecValue" Grid.Row="1" Grid.Column="1" />

                            <TextBlock Text="Current Out" Grid.Row="2" Grid.Column="0" />
                            <TextBlock x:Name="CurrentOutputValue" Grid.Row="2" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="InstallDriverButton" Content="Install Driver" Click="InstallDriverButton_Click" />
                            <Button x:Name="RefreshDevicesButton" Content="Refresh Devices" Click="RefreshDevicesButton_Click" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="OutputDeviceCombo" Width="360" Margin="0,0,8,0" DisplayMemberPath="Name">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#11243B" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#11243B" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EAF2FF" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A6FB0" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                                </ComboBox.Resources>
                            </ComboBox>
                            <Button x:Name="ApplyOutputButton" Content="Apply Device" Click="ApplyOutputButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="StartStopButton" Content="Start Server" Click="StartStopButton_Click" />
                        <Button x:Name="ToggleActionsButton" Content="Disable Actions" Click="ToggleActionsButton_Click" />
                        <Button x:Name="ToggleMuteButton" Content="Toggle Mute" Click="ToggleMuteButton_Click" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recent Actions / Events" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox Grid.Row="1" x:Name="LogsList" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
